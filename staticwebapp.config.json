    { "route": "/index.html", "allowedRoles": ["authenticated"] },
    { "route": "/modul1_grunnkurs.html", "allowedRoles": ["authenticated"] },
    { "route": "/modul2_daglig_arbeid.html", "allowedRoles": ["authenticated"] },
    { "route": "/modul3_avvik.html", "allowedRoles": ["authenticated"] },
    { "route": "/modul4_ledere_it.html", "allowedRoles": ["authenticated"] },
    { "route": "/modul5_fordypning.html", "allowedRoles": ["authenticated"] },
    { "route": "/gdpr_dosanddonts.html", "allowedRoles": ["authenticated"] }
